# syntax=docker/dockerfile:1
# GPU Worker image — based on NVIDIA CUDA runtime so libcublas, libcudnn, etc.
# are natively available to ctranslate2 / faster-whisper without LD_LIBRARY_PATH hacks.
FROM nvidia/cuda:12.8.1-cudnn-devel-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV LD_LIBRARY_PATH=/usr/local/cuda/lib64:${LD_LIBRARY_PATH}

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt/lists,sharing=locked \
    apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip python3-venv python3-dev \
    ca-certificates \
    build-essential \
    cmake \
    ninja-build \
    pkg-config \
    ffmpeg \
    libsndfile1 \
    libavformat-dev libavcodec-dev libavutil-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# --- Step 1: Bootstrap pip ---
RUN python3 -m pip install --upgrade pip setuptools wheel

# --- Step 2: Core deps (small graph, resolves quickly) ---
COPY requirements.txt ./
RUN --mount=type=cache,target=/root/.cache/pip \
    python3 -m pip install --default-timeout=300 --retries=10 -r requirements.txt

# --- Step 3: PyTorch + torchaudio CUDA stack ---
# Installed before model deps so later steps see them as satisfied constraints.
RUN --mount=type=cache,target=/root/.cache/pip \
    python3 -m pip install --default-timeout=300 --retries=10 \
    "torch>=2.1.0" "torchaudio>=2.1.0" \
    --index-url https://download.pytorch.org/whl/cu128

# --- Step 4: faster-whisper (pulls ctranslate2, tokenizers, huggingface-hub) ---
RUN --mount=type=cache,target=/root/.cache/pip \
    python3 -m pip install --default-timeout=300 --retries=10 \
    "faster-whisper>=1.0.0"

# --- Step 5: HF Transformers + accelerate ---
# Pinned to 4.x: transformers 5.x imports torchcodec which needs CUDA 13 libs.
RUN --mount=type=cache,target=/root/.cache/pip \
    python3 -m pip install --default-timeout=300 --retries=10 \
    "transformers>=4.36.0,<5.0.0" \
    "accelerate>=0.20.0"

# --- Step 6: pyannote.audio ---
# Installed alone — its 20+ transitive deps need torch/scipy already present.
RUN --mount=type=cache,target=/root/.cache/pip \
    python3 -m pip install --default-timeout=600 --retries=10 \
    "pyannote.audio>=3.1.0"

# --- Step 7: NeMo ASR toolkit (Parakeet, Canary) ---
RUN --mount=type=cache,target=/root/.cache/pip \
    python3 -m pip install --default-timeout=600 --retries=10 \
    "protobuf~=5.29.5" \
    "hydra-core>=1.3.0" \
    "omegaconf>=2.3.0" \
    "nemo_toolkit[asr]"

# --- Step 8: llama-cpp-python ---
# Try pre-built wheel first, fall back to source compilation with CUDA.
COPY vendor_wheels/ /app/vendor_wheels/
RUN if ls /app/vendor_wheels/llama_cpp_python*.whl 1>/dev/null 2>&1; then \
        echo "[DOCKER] Installing llama-cpp-python from pre-built wheel..." && \
        python3 -m pip install /app/vendor_wheels/llama_cpp_python*.whl; \
    else \
        echo "[DOCKER] Source-compiling llama-cpp-python with CUDA..." && \
        CMAKE_ARGS="-DGGML_CUDA=on -DGGML_CUDA_NO_VMM=ON" FORCE_CMAKE=1 \
        python3 -m pip install --default-timeout=600 --retries=5 \
        "llama-cpp-python>=0.2.50" --no-binary llama-cpp-python || \
        echo "[DOCKER] llama-cpp-python build failed (non-fatal, reconciliation will use deterministic fallback)"; \
    fi

# --- Step 9: Remove torchcodec (CUDA 13 dependency, not needed) ---
RUN python3 -m pip uninstall torchcodec -y 2>/dev/null || true

# Copy application code
COPY app/ app/
COPY scripts/ scripts/

RUN mkdir -p /data/sessions /data/certs

# Runtime environment
ENV SESSIONS_DIR=/data/sessions
ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1
ENV HF_HOME=/models
ENV TRANSFORMERS_CACHE=/models
ENV HUGGINGFACE_HUB_CACHE=/models

CMD ["python3", "-m", "app.workers.worker"]
