AUTH_TOKEN=dev-token
MODELS_DIR=./models
SESSIONS_DIR=./data/sessions
AUTO_CLEANUP_DRAFT_SESSIONS=true
DRAFT_SESSION_MAX_AGE_MINUTES=120
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_QUEUE=transcription_jobs
REDIS_PARTIAL_QUEUE=transcription_jobs_partial
SERVER_HOST=0.0.0.0
SERVER_PORT=8443
TLS_ENABLED=true
TLS_CERT_FILE=./data/certs/dev-cert.pem
TLS_KEY_FILE=./data/certs/dev-key.pem
TLS_AUTO_GENERATE_SELF_SIGNED=true
TLS_CERT_COMMON_NAME=localhost
TRANSPORT_CHUNK_MS=30000
DECODE_WINDOW_MS=30000
DECODE_STRIDE_MS=15000
COMMIT_STRIPE_MS=15000
WORKER_CONCURRENCY=1
PARTIAL_EVERY_N_CHUNKS=5
PARTIAL_COOLDOWN_SECONDS=120
MAX_CHUNK_MB=30
MAX_FILE_UPLOAD_MB=512
MAX_SESSION_CHUNKS=500
STRICT_CUDA=false
FORCED_LANGUAGE=
ALLOWED_LANGUAGES=
TRANSCRIPTION_MODE=verbatim_multilingual
